# Deny everything by default — only allowlisted files are tracked.
# This keeps config, build scripts, READMEs, and tests proprietary.
*

# Allow this gitignore itself
!.gitignore

# Cloudflare Pages rewrite/redirect rules (served from build root)
!_redirects

# Allowlist the top-level folders we intend to descend into.
# Each folder then has * to redeny contents, followed by !<path>/** to
# explicitly allow the assets we ship to Cloudflare Pages.
!css/
css/*
!css/**

!js/
js/*
!js/**

# Upsell page HTML is public (served to Kajabi visitors)
!upsells/
upsells/*
!upsells/pages/
!upsells/pages/**

# Checkout page HTML is public (same model — served to Kajabi visitors)
!checkouts/
checkouts/*
!checkouts/pages/
!checkouts/pages/**
!checkouts/bundles/
!checkouts/bundles/**

!shopify/
shopify/*
!shopify/pages/
!shopify/pages/**

# Belt-and-suspenders: block common noise even if it sneaks into allowed dirs
.DS_Store
._*
.Spotlight-V100
.Trashes
Thumbs.db
*.swp
*.swo
__pycache__/
*.py[cod]
.env
.env.*
*.log
.vscode/
.idea/
node_modules/
